    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  let output = item.json.output;\n\n  // Eliminar markdown y espacios\n  output = output\n    .replace(/```json/g, '')\n    .replace(/```/g, '')\n    .trim();\n\n  let clasificacion;\n\n  try {\n    // Si viene como JSON {\"clasificacion\":\"VIP\"}\n    const parsed = JSON.parse(output);\n\n    if (typeof parsed === 'object' && parsed.clasificacion) {\n      clasificacion = parsed.clasificacion;\n    } else {\n      clasificacion = parsed;\n    }\n  } catch {\n    // Si viene como string simple \"VIP\"\n    clasificacion = output.replace(/\"/g, '').trim();\n  }\n\n  return {\n    json: {\n      tipo_cliente: clasificacion\n    }\n  };\n});"
      },
