        "jsCode": "// Espera mensajes tipo: \"APROBAR <id>\" o \"RECHAZAR <id>\"\nconst text = ($input.first().json.messages?.[0]?.text?.body || '').trim().toUpperCase();\nconst match = text.match(/(APROBAR|RECHAZAR)\\s+(\\S+)/);\nif (!match) {\n  return [];\n}\nreturn [{\n  json: {\n    accion: match[1],\n    id: match[2],\n    approved: match[1] === 'APROBAR'\n  }\n}];"
